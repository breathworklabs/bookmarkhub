# Google Analytics Measurement ID
# Get this from your Google Analytics account: https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN
# Get this from your Sentry project settings: https://sentry.io
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000

# TwitterAPI.io API Key (Optional - for live demo data)
# Get your API key from: https://twitterapi.io/dashboard
# Free tier: $1 credit, 1 request per 5 seconds
# If not set, demo mode will use static fallback data
VITE_TWITTER_API_KEY=your_api_key_here
