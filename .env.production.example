# Railway Production Environment Variables
# Copy these to Railway's environment variables section

# Node environment
NODE_ENV=production

# Server Configuration
PORT=3000

# Application URL
VITE_APP_URL=https://your-app.railway.app

# Sentry Configuration (optional)
VITE_SENTRY_DSN=your-sentry-dsn-here
VITE_SENTRY_ENVIRONMENT=production

# Twitter/X API Configuration (if using proxy)
ENABLE_API_PROXY=false
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Feature Flags
VITE_ENABLE_EXTENSION=true
VITE_ENABLE_TAGS=true
VITE_ENABLE_ANALYTICS=false

# Security
VITE_ALLOWED_ORIGINS=https://your-app.railway.app,https://bookmarkhub.breathworklabs.com

# Storage Configuration
VITE_MAX_BOOKMARKS=10000
VITE_MAX_TAGS=100

# Performance
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_CACHE=true

# Monitoring
VITE_ENABLE_MONITORING=true
VITE_LOG_LEVEL=info
