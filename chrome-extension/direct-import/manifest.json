{
  "manifest_version": 3,
  "name": "BookmarkHub - Twitter Bookmark Manager",
  "version": "1.1.2",
  "description": "Import and manage your Twitter/X bookmarks with BookmarkHub's powerful interface",
  "permissions": ["scripting", "tabs", "storage", "activeTab"],
  "host_permissions": ["*://twitter.com/*", "*://x.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://twitter.com/*", "*://x.com/*"],
      "js": ["content-scripts/twitter-api-client.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://bookmarkhub.app/*"],
      "js": ["content-scripts/bookmarkhub-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.png"],
      "matches": ["*://twitter.com/*", "*://x.com/*"]
    }
  ]
}
