{
  "manifest_version": 3,
  "name": "BookmarkX - Automated Extractor",
  "version": "3.0.1",
  "description": "Automatically extract ALL your X/Twitter bookmarks with one click - no manual navigation required!",

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "permissions": ["activeTab", "storage", "tabs", "scripting", "cookies"],

  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content-scripts/localhost-bridge.js"],
      "run_at": "document_start"
    }
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BookmarkX - Extract Bookmarks",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  }
}
