{
  "name": "bookmarkhub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "author": "Breathwork Labs <hello@breathworklabs.com>",
  "homepage": "https://bookmarkhub.breathworklabs.com",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "NODE_ENV=production npm run build",
    "build:railway": "rm -rf dist && tsc -b && vite build",
    "start:prod": "NODE_ENV=production node server.js",
    "start": "node server.js",
    "vercel-build": "npm run test -- --run && npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "storybook": "storybook dev -p 6006 -c storybook/config",
    "build-storybook": "storybook build -c storybook/config",
    "fetch-demo-tweets": "node scripts/fetch-demo-tweets.js"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "dependencies": {
    "@chakra-ui/modal": "^2.3.1",
    "@chakra-ui/react": "^3.27.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@sentry/react": "^10.18.0",
    "@tanstack/react-query": "^5.89.0",
    "@types/dompurify": "^3.0.5",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.12.2",
    "compression": "^1.7.4",
    "compromise": "^14.14.4",
    "dompurify": "^3.3.0",
    "express": "^4.21.2",
    "framer-motion": "^12.23.16",
    "helmet": "^8.0.0",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-datepicker": "^8.7.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.9.3",
    "web-vitals": "^5.1.0",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-a11y": "^9.1.10",
    "@storybook/react-vite": "^9.1.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.10",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "less": "^4.4.2",
    "prettier": "^3.6.2",
    "storybook": "^9.1.10",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^7.1.6",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^3.2.4"
  }
}
